local function SFVUD_fake_script() -- WeirdAghfly.Troll Fly script 
	local script = Instance.new('LocalScript', WeirdAghfly)

	script.Parent.MouseButton1Click:Connect(function()
	local player = game.Players.LocalPlayer
	local character = player.Character or player.CharacterAdded:Wait()
	local humanoid = character:WaitForChild("Humanoid")
	local rootPart = character:WaitForChild("HumanoidRootPart")
	
	local speed = 50 -- Adjust this value to change the flying speed
	local isFlying = false
	
	local function toggleFly()
		isFlying = not isFlying
		humanoid.PlatformStand = isFlying -- Prevents default walking physics
		if isFlying then
			print("Flying enabled!")
		else
			print("Flying disabled!")
		end
	end
	
	game:GetService("UserInputService").InputBegan:Connect(function(input, gameProcessedEvent)
		if gameProcessedEvent then return end -- Don't process input that the game already handled
	
		if input.KeyCode == Enum.KeyCode.F then -- Change 'F' to your desired toggle key
			toggleFly()
		end
	end)
	
	game:GetService("RunService").Stepped:Connect(function()
		if isFlying then
			local moveDirection = Vector3.new(0, 0, 0)
	
			-- Get input from WASD keys (or your game's movement keys)
			if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.W) then
				moveDirection += rootPart.CFrame.LookVector
			end
			if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.S) then
				moveDirection -= rootPart.CFrame.LookVector
			end
			if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.A) then
				moveDirection -= rootPart.CFrame.RightVector
			end
			if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.D) then
				moveDirection += rootPart.CFrame.RightVector
			end
			if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.Space) then
				moveDirection += Vector3.new(0, 1, 0) -- Move up
			end
			if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.LeftShift) then
				moveDirection -= Vector3.new(0, 1, 0) -- Move down
			end
	
			-- Normalize the movement direction if it's not zero
			if moveDirection.Magnitude > 0 then
				moveDirection = moveDirection.Unit
			end
	
			-- Apply the velocity
			rootPart.Velocity = moveDirection * speed
		else
			-- If not flying, reset velocity to allow normal movement
			rootPart.Velocity = Vector3.new(0, 0, 0)
		end
	end)
	
	-- Ensure the character is loaded initially
	if not character:IsDescendantOf(game) then
		player.CharacterAdded:Connect(function(newCharacter)
			character = newCharacter
			humanoid = character:WaitForChild("Humanoid")
			rootPart = character:WaitForChild("HumanoidRootPart")
		end)
	end
	end)
end
coroutine.wrap(SFVUD_fake_script)()
